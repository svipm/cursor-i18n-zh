{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "汉化工作台",
  "version": "0.4.0",
  "identifier": "com.svipm.i18n-workbench",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "汉化工作台",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "resizable": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "shortDescription": "管理 Cursor 和 Claude 的汉化, MCP, Skill 与提示词",
    "longDescription": "面向 Cursor, Claude Desktop 和 Claude Code 的跨平台汉化与扩展管理工作台"
  }
}
