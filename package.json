{
  "name": "cursor-i18n-zh",
  "version": "0.3.1",
  "description": "Cursor Windows 桌面端中文汉化补丁工具: 支持简体, 繁体, 一键安装和恢复",
  "type": "commonjs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/svipm/cursor-i18n-zh.git"
  },
  "bin": {
    "cursor-i18n-zh": "src/cli.js"
  },
  "scripts": {
    "apply": "node src/cli.js apply",
    "patch-install": "node src/cli.js install",
    "restore": "node src/cli.js restore",
    "status": "node src/cli.js status",
    "locate": "node src/cli.js locate",
    "scan": "node src/cli.js scan",
    "lang": "node src/cli.js lang",
    "check": "node src/cli.js check",
    "dict-check": "node src/cli.js dict-check",
    "helper": "node scripts/helper.js",
    "ui": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/gui.ps1",
    "package": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package.ps1",
    "test": "node scripts/test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "acorn": "8.17.0",
    "opencc-js": "1.4.0"
  }
}
